# Copier ce fichier vers .deploy.local.env puis compléter les valeurs.
# Le fichier .deploy.local.env ne doit jamais être commité.

# Identité managée Azure utilisée par GitHub Actions via OIDC
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000

# Storage Account Azure utilisé pour publier les supports HTML
AZURE_STORAGE_ACCOUNT=mycourses
STATIC_WEBSITE_ENDPOINT=https://mycourses.z28.web.core.windows.net/

# Ressources Azure nécessaires pour créer la federated credential
AZURE_RESOURCE_GROUP=mycourses
AZURE_IDENTITY_NAME=id-github-mycourses-deploy

# Optionnel, main par défaut
# GITHUB_BRANCH=main